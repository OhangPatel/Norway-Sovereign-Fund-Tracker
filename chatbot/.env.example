# ──────────────────────────────────────────────────────────────────────────
# Copy this file to ".env" (same folder) and paste YOUR key below.
# ".env" is gitignored — it is NEVER committed, so your key stays private even
# though the repo is public. There is no UI to enter a key; this is the only place.
#
# Get a FREE Gemini key:  https://aistudio.google.com/apikey
# Tip: keep billing DISABLED on the Google project so you can never be charged.
# ──────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=

# ── Cost / abuse controls (defaults are safe; leave blank to use them) ───────
# GEMINI_MODEL=gemini-2.5-flash-lite # bigger free-tier daily quota than 2.5-flash
#                                     #   (1.5 retired; 2.0 may be limit:0). 2.5-flash
#                                     #   answers multi-item questions more completely.
# MAX_OUTPUT_TOKENS=1536    # must cover thinking + the answer on 2.5/3 models
# THINKING_BUDGET=512       # internal-reasoning cap; do NOT set 0 (breaks tool replies)
# MAX_INPUT_CHARS=2000
# MAX_HISTORY_MESSAGES=10
# RATE_PER_MINUTE=6
# RATE_PER_DAY=100          # hard daily ceiling on Gemini calls (persisted)

# ── Network / deployment (set these when deploying publicly) ─────────────────
# ALLOWED_ORIGINS=https://yourapp.example   # lock CORS to your real frontend
# TRUST_PROXY=true                          # behind a proxy: use X-Forwarded-For
# CHATBOT_HOST=0.0.0.0                       # PaaS hosts need 0.0.0.0
# CHATBOT_RELOAD=0                           # disable dev auto-reload in prod
# CHATBOT_PORT=8001                          # local port (PaaS injects $PORT)
